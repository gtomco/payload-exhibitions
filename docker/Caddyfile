# Local/dev-friendly: HTTP only (no ACME). Production: set PUBLIC_PROTOCOL=https
# and terminate TLS on 443; keep www → apex redirect (canonical host is non-www).

{
	auto_https off
}

# Canonical host is non-www (matches NEXT_PUBLIC_SERVER_URL).
http://www.{$ROOT_DOMAIN} {
	redir http://{$ROOT_DOMAIN}{uri} permanent
}

http://{$ROOT_DOMAIN}, http://*.{$ROOT_DOMAIN} {
	reverse_proxy app:3000 {
		header_up Host {host}
		header_up X-Forwarded-Host {host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Real-IP {remote_host}
	}
}

