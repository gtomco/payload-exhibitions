# --- Database (required) ---
# Local:
# DATABASE_URL=postgresql://payload:payload@localhost:5432/payload
# Remote:
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5459/payload-exhibitions?sslmode=disable
#DATABASE_URL=postgres://postgres:d53f6ae9d24767052517@84.247.130.70:5459/payload-exhibitions?sslmode=disable
DATABASE_URL=postgresql://payload:payload@localhost:5432/payload

# Used to encrypt JWT tokens — must stay stable for a given database
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Canonical public origin for the IX apex / admin / media (no trailing slash)
NEXT_PUBLIC_SERVER_URL=https://i-exhibitions.com

# --- Multi-host routing (Docker / VPS) ---
# Apex → IX main site; {slug}.{ROOT_DOMAIN} → microsite
ROOT_DOMAIN=i-exhibitions.com
PUBLIC_PROTOCOL=https
# Prefer X-Forwarded-Host / Proto behind Caddy/Traefik/nginx
TRUST_PROXY=true
# Allow /m/{slug} path-based microsites (set false in public production)
ENABLE_PATH_MICROSITES=false
# Optional non-default port for local Docker (also inferred from NEXT_PUBLIC_SERVER_URL)
# PUBLIC_PORT=3002

# --- Secrets ---
CRON_SECRET=YOUR_CRON_SECRET_HERE
PREVIEW_SECRET=YOUR_PREVIEW_SECRET_HERE

# --- Sales CRM (server-side only; booth/floor data) ---
CRM_API_URL=http://localhost:8081/api
CRM_ASSETS_URL=http://localhost:8081

# --- Outbound email (visitor ticket confirmations) ---
# Without SMTP_HOST, Payload uses an Ethereal test account (dev only — not real delivery).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_ADDRESS=noreply@i-exhibitions.com
SMTP_FROM_NAME=Iceberg Exhibitions
# true for port 465
SMTP_SECURE=false
# Skip SMTP connection verify on boot
SMTP_SKIP_VERIFY=false
